{
  "manifest_version": 2,
  "name": "Cat Auto Catcher",
  "version": "0.1.0",
  "description": "Watches the current page for the cat trigger and sends cat from a simple Firefox control.",
  "permissions": ["activeTab", "tabs", "<all_urls>"],
  "background": {
    "scripts": ["src/background.js"],
    "persistent": false
  },
  "browser_action": {
    "default_title": "Cat Auto Catcher",
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon.svg"
    }
  },
  "icons": {
    "48": "icons/icon.svg"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "cat-autocatcher@championautofinance.local"
    }
  }
}
